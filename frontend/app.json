{
  "expo": {
    "name": "Gali'Pet",
    "slug": "galipet",
    "version": "1.0.0",
    "scheme": "galipet",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F97316"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.galipet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F97316"
      },
      "package": "com.galipet.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Gali'Pet a besoin de votre position pour trouver des professionnels près de chez vous."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
